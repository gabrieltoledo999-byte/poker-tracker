+        width: `${Math.max(14, drop.size * 0.82)}px`,
+        height: `${Math.max(14, drop.size * 0.82)}px`,
+        background: "radial-gradient(circle at 30% 30%, #fef3c7 0%, #f59e0b 58%, #92400e 100%)",
+      }}
+    >
+      $
+    </span>
+  );
+}
